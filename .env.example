# NetSuite TBA (Token Based Authentication) credentials
# Create an integration record in NetSuite: Setup > Integration > Manage Integrations
NS_ACCOUNT_ID=your_account_id          # e.g. 1234567 or 1234567_SB1 for sandbox
NS_CONSUMER_KEY=your_consumer_key
NS_CONSUMER_SECRET=your_consumer_secret
NS_TOKEN_ID=your_token_id
NS_TOKEN_SECRET=your_token_secret

# NetSuite RESTlet for payment creation (deploy the bundled SuiteScript)
# Setup > Customisation > Scripting > Script Deployments → get script/deploy IDs
NS_PAYMENT_RESTLET_SCRIPT_ID=customscript_portal_payment
NS_PAYMENT_RESTLET_DEPLOY_ID=customdeploy_portal_payment

# JWT signing secret – generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars

# Contact custom fields (Customisation > Lists, Records & Fields > Contact Fields)
# Enable portal access flag (Checkbox) – when ticked, triggers the invite email
NS_CONTACT_ENABLE_FIELD=custentity_pret_enable_customer_portal
# Portal password hash (Free-Form Text) – stores bcrypt hash set by the contact
NS_CONTACT_PWD_FIELD=custentity_pret_customer_portal_password

# Shared secret used by the NetSuite SuiteScript to call the /api/auth/invite endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
PORTAL_INVITE_SECRET=change_me_to_a_long_random_secret

# SMTP email settings (for password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com   # optional, defaults to SMTP_USER

# Public base URL of the portal (used to build reset links in emails)
PORTAL_URL=https://your-portal-domain.com

# Anthropic API key for PRETty AI agent (demo mode only)
ANTHROPIC_API_KEY=your_anthropic_api_key
